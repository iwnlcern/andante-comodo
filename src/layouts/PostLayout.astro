---
import EntryLayout from './EntryLayout.astro';
import EpistemicStatus from '#components/post/EpistemicStatus.astro';
import PostMeta from '#components/post/PostMeta.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface AiMeta {
  level: number;
  tools?: string[];
  note?: string;
}

interface Props {
  title: string;
  description: string;
  date?: Date;
  updated?: Date;
  tags: string[];
  headings?: Heading[];
  backHref?: string;
  backLabel?: string;
  dateLabel?: string;
  wordCount?: number;
  readingMinutes?: number;
  epistemic?: string;
  ai?: AiMeta;
  datePublished?: Date;
  dateModified?: Date;
}

const {
  title,
  description,
  date,
  updated,
  tags,
  headings = [],
  backHref = '/blog',
  backLabel = 'Back to blog',
  dateLabel,
  wordCount,
  readingMinutes,
  epistemic,
  ai,
  datePublished,
  dateModified,
} = Astro.props;
---

<EntryLayout
  title={title}
  description={description}
  backHref={backHref}
  backLabel={backLabel}
  readingApparatus
  headings={headings}
  datePublished={datePublished}
  dateModified={dateModified}
>
  <PostMeta
    slot="meta"
    date={date}
    dateLabel={dateLabel}
    updated={updated}
    wordCount={wordCount}
    readingMinutes={readingMinutes}
    ai={ai}
    tags={tags}
  />
  {epistemic && <EpistemicStatus slot="before-body" value={epistemic} />}
  <slot />
</EntryLayout>
