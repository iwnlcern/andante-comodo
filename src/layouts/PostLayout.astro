---
import EntryLayout from './EntryLayout.astro';
import Tag from '#components/common/Tag.astro';
import EpistemicStatus from '#components/post/EpistemicStatus.astro';
import AiSignal from '#components/post/AiSignal.astro';
import MetaPopover from '#components/common/MetaPopover.astro';
import { formatMetaDate } from '#lib/content/post-meta.mjs';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface AiMeta {
  level: number;
  tools?: string[];
  note?: string;
}

interface Props {
  title: string;
  description: string;
  date?: Date;
  updated?: Date;
  tags: string[];
  headings?: Heading[];
  backHref?: string;
  backLabel?: string;
  dateLabel?: string;
  wordCount?: number;
  readingMinutes?: number;
  epistemic?: string;
  ai?: AiMeta;
  datePublished?: Date;
  dateModified?: Date;
}

const {
  title,
  description,
  date,
  updated,
  tags,
  headings = [],
  backHref = '/blog',
  backLabel = 'Back to blog',
  dateLabel,
  wordCount,
  readingMinutes,
  epistemic,
  ai,
  datePublished,
  dateModified,
} = Astro.props;

const formattedDate = date ? formatMetaDate(date) : null;
const formattedUpdated = updated ? formatMetaDate(updated) : null;
const readingWords = typeof wordCount === 'number' ? `${wordCount.toLocaleString('en-US')} words` : undefined;
---

<EntryLayout
  title={title}
  description={description}
  backHref={backHref}
  backLabel={backLabel}
  readingApparatus
  headings={headings}
  datePublished={datePublished}
  dateModified={dateModified}
>
  <div slot="meta" class="flex flex-wrap items-center gap-3 text-sm text-text-secondary">
    {date && (
      <time datetime={date.toISOString()}>{dateLabel ? `${dateLabel} ${formattedDate}` : formattedDate}</time>
    )}
    {updated && (
      <Fragment>
        <span>·</span>
        <time datetime={updated.toISOString()}>Updated {formattedUpdated}</time>
      </Fragment>
    )}
    {typeof readingMinutes === 'number' && (
      <Fragment>
        <span>·</span>
        <MetaPopover>
          <span slot="trigger" tabindex="0" aria-label={readingWords}>{readingMinutes} min read</span>
          {readingWords}
        </MetaPopover>
      </Fragment>
    )}
    {ai && (
      <Fragment>
        <span>·</span>
        <AiSignal ai={ai} />
      </Fragment>
    )}
    {tags.length > 0 && <span>·</span>}
    {tags.map((tag) => (
      <Tag tag={tag} href={`/tags/${tag}`} />
    ))}
  </div>
  {epistemic && <EpistemicStatus slot="before-body" value={epistemic} />}
  <slot />
</EntryLayout>
