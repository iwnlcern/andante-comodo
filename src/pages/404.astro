---
import BaseLayout from '#layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="Page not found.">
  <div class="flex flex-col items-center justify-center py-20">
    <h1 class="error-code mb-4">404</h1>
    <p class="text-xl text-text-secondary mb-8">Page not found</p>
    <a
      href="/"
      class="px-4 py-2 border border-border rounded hover:border-accent hover:text-accent transition-colors"
    >
      Go home
    </a>
  </div>
</BaseLayout>
