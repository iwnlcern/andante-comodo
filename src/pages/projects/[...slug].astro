---
import { render } from 'astro:content';
import EntryLayout from '#layouts/EntryLayout.astro';
import Tag from '#components/common/Tag.astro';
import { collectionPaths } from '#lib/content/collection-paths';

export const getStaticPaths = () => collectionPaths('projects', { propKey: 'project' });

const { project } = Astro.props;
const { Content, headings } = await render(project);

const formattedDate = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  timeZone: 'UTC',
});
---

<EntryLayout title={project.data.title} description={project.data.description} backHref="/projects" backLabel="Back to projects" readingApparatus headings={headings}>
  <div slot="meta">
    <p class="text-lg text-text-secondary mb-4">{project.data.description}</p>
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <span class="text-sm text-text-secondary">{formattedDate}</span>
      {project.data.tags.map((tag) => (
        <Tag tag={tag} href={`/tags/${tag}`} />
      ))}
    </div>
    <div class="flex gap-4">
      {project.data.github && (
        <a
          href={project.data.github}
          class="text-sm text-text-secondary hover:text-accent"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub &nearr;
        </a>
      )}
      {project.data.live && (
        <a
          href={project.data.live}
          class="text-sm text-text-secondary hover:text-accent"
          target="_blank"
          rel="noopener noreferrer"
        >
          Live Demo &nearr;
        </a>
      )}
    </div>
  </div>
  <Content />
</EntryLayout>
