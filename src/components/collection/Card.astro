---
import Tag from '#components/common/Tag.astro';

interface Props {
  title: string;
  description?: string;
  href: string;
  date?: Date;
  tags?: string[];
  accent?: string;
  meta?: string;
  media?: { audio?: string };
}

const { title, description, href, date, tags = [], accent, meta, media } = Astro.props;
const cardStyle = accent ? `--card-accent: ${accent};` : undefined;
const tagData = tags.map((tag) => tag.toLowerCase()).join(',');

const formattedDate = date
  ? date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : null;
---

<article
  class="card group p-4 border rounded transition-transform transition-colors hover:-translate-y-1 hover:shadow-[0_10px_24px_rgba(0,0,0,0.35)]"
  style={cardStyle}
  data-collection-item
  data-filter-tags={tagData || undefined}
>
  <h3 class="text-lg">
    <a
      href={href}
      class="font-medium text-text-primary hl-link focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 rounded-sm"
    >
      {title}
    </a>
  </h3>
  {meta && (
    <p class="mt-1 text-sm text-text-secondary">{meta}</p>
  )}
  {description && (
    <p class="mt-1 text-sm text-text-secondary line-clamp-2">
      {description}
    </p>
  )}
  {(formattedDate || tags.length > 0) && (
    <div class="mt-3 flex flex-wrap items-center gap-2">
      {formattedDate && (
        <time class="text-xs text-text-secondary" datetime={date?.toISOString()}>{formattedDate}</time>
      )}
      {tags.length > 0 && formattedDate && (
        <span class="text-xs text-text-secondary">·</span>
      )}
      {tags.slice(0, 3).map((tag) => (
        <Tag tag={tag} href={`/tags/${tag}`} />
      ))}
    </div>
  )}
  {media?.audio && (
    <audio
      src={media.audio}
      class="mt-3 h-8 w-full"
      controls
      preload="none"
      aria-label={`Listen to ${title}`}
    />
  )}
</article>

<style>
  .card {
    border-color: var(--card-accent, rgb(var(--color-border) / 1));
  }
</style>

<script>
  import '#scripts/collection-audio.ts';
</script>
