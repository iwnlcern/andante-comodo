---
import { newsletter } from '#config/newsletter';

type Variant = 'inline' | 'footer';

interface Props {
  variant?: Variant;
}

const { variant = 'inline' } = Astro.props;

const title = newsletter.title ?? 'Get new posts by email';
const description = newsletter.description ?? 'Occasional updates. No spam.';
const placeholder = newsletter.placeholder ?? 'you@example.com';
const buttonLabel = newsletter.buttonLabel ?? 'Subscribe';
const emailFieldName = newsletter.emailFieldName ?? 'EMAIL';
const recaptchaSiteKey = (newsletter.recaptchaSiteKey ?? '').trim();
const recaptchaAction = (newsletter.recaptchaAction ?? 'newsletter_subscribe').trim();
const recaptchaEnabled = recaptchaSiteKey.length > 0;
const honeypotFieldName = (newsletter.honeypotFieldName ?? '').trim();

const isFooter = variant === 'footer';
const showRecaptchaDevNote = import.meta.env.DEV && !recaptchaEnabled;
---

<section data-pagefind-ignore class={isFooter ? 'w-full' : 'w-full rounded-lg border border-border bg-surface p-6'}>
  <div class={isFooter ? 'flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between' : 'space-y-3'}>
    <div class={isFooter ? 'space-y-1' : 'space-y-2'}>
      <p class="text-base font-semibold">{title}</p>
      <p class="text-sm text-text-secondary">{description}</p>
    </div>
    <form
      action="/api/newsletter-subscribe"
      method="POST"
      data-newsletter-form
      data-recaptcha-enabled={recaptchaEnabled ? 'true' : 'false'}
      data-recaptcha-sitekey={recaptchaSiteKey}
      data-recaptcha-action={recaptchaAction}
      class={isFooter ? 'flex w-full max-w-md flex-col gap-2 sm:items-end' : 'flex w-full flex-col gap-2'}
    >
      {honeypotFieldName && <input type="text" name={honeypotFieldName} value="" class="hidden" tabindex="-1" autocomplete="off" />}
      <label class="sr-only" for={`newsletter-email-${variant}`}>
        Email address
      </label>
      <div class={isFooter ? 'flex w-full flex-col gap-2 sm:flex-row sm:items-center sm:justify-end' : 'flex w-full flex-col gap-2 sm:flex-row sm:items-center'}>
        <input
          id={`newsletter-email-${variant}`}
          name={emailFieldName}
          type="email"
          required
          autocomplete="email"
          placeholder={placeholder}
          class="w-full flex-1 rounded-md border border-border bg-background px-3 py-2 text-sm text-text-primary placeholder:text-text-secondary focus:outline-none focus:ring-2 focus:ring-accent/50"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded-md bg-accent px-4 py-2 text-sm font-medium text-white transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50"
          aria-disabled="false"
        >
          {buttonLabel}
        </button>
      </div>
      {recaptchaEnabled && (
        <div class="space-y-2">
          <input type="hidden" name="g-recaptcha-response" value="" data-recaptcha-response />
          <p class="hidden text-xs text-red-300" data-recaptcha-error>
            reCAPTCHA verification failed. Please try again.
          </p>
          <p class="hidden text-xs text-red-300" data-recaptcha-load-error>
            reCAPTCHA failed to load. Disable blockers and refresh.
          </p>
        </div>
      )}
      <p class="hidden text-xs" data-newsletter-status aria-live="polite"></p>
    </form>
  </div>
  {showRecaptchaDevNote && (
    <p class="mt-3 text-xs text-text-secondary">
      Set `PUBLIC_RECAPTCHA_SITE_KEY` to enable reCAPTCHA.
    </p>
  )}
</section>

<script is:inline>
  (() => {
    if (typeof window === 'undefined') return;

    const getRecaptchaPromise = (siteKey) => {
      if (!siteKey) return Promise.reject(new Error('Missing reCAPTCHA site key.'));
      if (window.grecaptcha && window.grecaptcha.ready && window.grecaptcha.execute) {
        return Promise.resolve(window.grecaptcha);
      }
      if (window.__newsletterRecaptchaPromise) return window.__newsletterRecaptchaPromise;

      window.__newsletterRecaptchaPromise = new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = `https://www.google.com/recaptcha/api.js?render=${encodeURIComponent(siteKey)}`;
        script.async = true;
        script.defer = true;
        script.dataset.newsletterRecaptcha = 'true';
        script.onload = () => {
          if (window.grecaptcha && window.grecaptcha.ready && window.grecaptcha.execute) {
            resolve(window.grecaptcha);
          } else {
            reject(new Error('Unable to load reCAPTCHA script.'));
          }
        };
        script.onerror = () => reject(new Error('Unable to load reCAPTCHA script.'));
        document.head.appendChild(script);
      });

      return window.__newsletterRecaptchaPromise;
    };

    const forms = Array.from(document.querySelectorAll('form[data-newsletter-form]'));
    if (forms.length === 0) return;
    const firstProtectedForm = forms.find(
      (form) => form.dataset.recaptchaEnabled === 'true',
    );
    if (firstProtectedForm) {
      getRecaptchaPromise(firstProtectedForm.dataset.recaptchaSitekey || '').catch(() => {});
    }

    if (!window.__newsletterSubmitBound) {
      window.__newsletterSubmitBound = true;
      document.addEventListener('submit', async (event) => {
        const form = event.target;
        if (!(form instanceof HTMLFormElement)) return;
        if (!form.matches('[data-newsletter-form]')) return;

        event.preventDefault();

        const statusText = form.querySelector('[data-newsletter-status]');
        const submitButton = form.querySelector('button[type="submit"]');
        const tokenInput = form.querySelector('[data-recaptcha-response]');
        const recaptchaErrorText = form.querySelector('[data-recaptcha-error]');
        const recaptchaLoadErrorText = form.querySelector('[data-recaptcha-load-error]');

        if (statusText) {
          statusText.classList.add('hidden');
          statusText.classList.remove('text-red-300', 'text-green-300');
          statusText.textContent = '';
        }
        if (recaptchaErrorText) recaptchaErrorText.classList.add('hidden');
        if (recaptchaLoadErrorText) recaptchaLoadErrorText.classList.add('hidden');

        if (submitButton instanceof HTMLButtonElement) submitButton.disabled = true;

        const recaptchaEnabled = form.dataset.recaptchaEnabled === 'true';
        if (recaptchaEnabled) {
          try {
            const siteKey = form.dataset.recaptchaSitekey || '';
            const action = form.dataset.recaptchaAction || 'newsletter_subscribe';
            const grecaptcha = await getRecaptchaPromise(siteKey);
            const token = await grecaptcha.execute(siteKey, { action });
            if (!token || typeof token !== 'string') {
              throw new Error('Empty reCAPTCHA token.');
            }
            if (tokenInput) tokenInput.value = token;
          } catch (error) {
            const message =
              error instanceof Error ? error.message : 'reCAPTCHA verification failed.';
            const isLoadError =
              message.includes('Unable to load reCAPTCHA script.') ||
              message.includes('Missing reCAPTCHA site key.');
            if (isLoadError) {
              if (recaptchaLoadErrorText) recaptchaLoadErrorText.classList.remove('hidden');
            } else if (recaptchaErrorText) {
              recaptchaErrorText.textContent = message;
              recaptchaErrorText.classList.remove('hidden');
            }
            if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
            return;
          }
        }

        try {
          const response = await fetch('/api/newsletter-subscribe', {
            method: 'POST',
            headers: {
              Accept: 'application/json',
            },
            body: new FormData(form),
          });

          const contentType = response.headers.get('content-type') || '';
          let payload = null;
          let rawText = '';
          if (contentType.includes('application/json')) {
            payload = await response.json().catch(() => null);
          } else {
            rawText = await response.text().catch(() => '');
          }
          const ok = response.ok && payload && payload.ok;
          const fallbackError = `Subscription failed (${response.status}). Please try again.`;

          if (statusText) {
            statusText.classList.remove('hidden');
            statusText.classList.add(ok ? 'text-green-300' : 'text-red-300');
            statusText.textContent = ok
              ? payload.message || 'Subscription successful. Please check your inbox.'
              : payload?.error || fallbackError;
          }

          if (ok) {
            form.reset();
            if (tokenInput) tokenInput.value = '';
          }
        } catch (_error) {
          if (statusText) {
            statusText.classList.remove('hidden');
            statusText.classList.add('text-red-300');
            statusText.textContent = 'Network error. Please try again.';
          }
        } finally {
          if (submitButton instanceof HTMLButtonElement) submitButton.disabled = false;
        }
      });
    }
  })();
</script>
