---
---

<div id="search-container">
  <button
    id="search-trigger"
    type="button"
    class="flex items-center gap-2 px-3 py-1.5 text-sm text-text-secondary border border-border rounded hover:border-text-secondary transition-colors"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="search-modal"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <span class="hidden sm:inline">Search</span>
    <kbd class="hidden sm:inline text-xs text-text-secondary">⌘K</kbd>
  </button>
</div>

<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-title"
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-background/80 backdrop-blur-sm" id="search-backdrop"></div>
  <div class="relative flex items-start justify-center pt-[20vh] px-4">
    <div class="w-full max-w-xl bg-surface border border-border rounded-lg overflow-hidden">
      <h2 id="search-title" class="sr-only">Search site content</h2>
      <div id="pagefind-container"></div>
    </div>
  </div>
</div>

<script>
  async function initSearch() {
    const existingCleanup = window.__searchCleanup;
    if (typeof existingCleanup === 'function') {
      existingCleanup();
    }

    const trigger = document.getElementById('search-trigger');
    const modal = document.getElementById('search-modal');
    const backdrop = document.getElementById('search-backdrop');
    const container = document.getElementById('pagefind-container');

    if (!trigger || !modal || !backdrop || !container) return;

    let pagefindLoaded = false;
    let lastFocusedElement = null;
    let focusObserver = null;
    const focusableSelector =
      'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

    const isOpen = () => !modal.classList.contains('hidden');

    async function openSearch() {
      if (isOpen()) return;

      lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      trigger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';

      if (!pagefindLoaded) {
        try {
          if (!window.PagefindUI) {
            await new Promise((resolve, reject) => {
              const script = document.createElement('script');
              script.src = '/pagefind/pagefind-ui.js';
              script.async = true;
              script.onload = resolve;
              script.onerror = reject;
              document.head.appendChild(script);
            });
          }

          if (!window.PagefindUI) {
            throw new Error('Pagefind UI failed to load.');
          }

          new window.PagefindUI({
            element: '#pagefind-container',
            bundlePath: '/pagefind/',
            showSubResults: true,
            showImages: false,
          });
          pagefindLoaded = true;
        } catch (e) {
          console.error('[search] Pagefind failed to load.', e);
          container.innerHTML = '<p class="p-4 text-text-secondary">Search is currently unavailable.</p>';
        }
      }

      const focusSearchInput = () => {
        const input = container.querySelector('input');
        if (input instanceof HTMLElement) {
          input.focus();
          focusObserver?.disconnect();
          focusObserver = null;
          return true;
        }
        return false;
      };

      if (!focusSearchInput()) {
        focusObserver?.disconnect();
        focusObserver = new MutationObserver(() => {
          focusSearchInput();
        });
        focusObserver.observe(container, { childList: true, subtree: true });

        const fallback = modal.querySelector(focusableSelector);
        if (fallback instanceof HTMLElement) fallback.focus();
      }
    }

    function closeSearch() {
      if (!isOpen()) return;

      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
      trigger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      focusObserver?.disconnect();
      focusObserver = null;

      if (lastFocusedElement instanceof HTMLElement && document.contains(lastFocusedElement)) {
        lastFocusedElement.focus();
      }
    }

    trigger.addEventListener('click', openSearch);
    backdrop.addEventListener('click', closeSearch);

    const handleKeydown = (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (!isOpen()) {
          openSearch();
        } else {
          closeSearch();
        }
      }

      if (e.key === 'Escape' && isOpen()) {
        closeSearch();
      }

      if (e.key !== 'Tab' || !isOpen()) return;

      const focusables = Array.from(modal.querySelectorAll(focusableSelector)).filter(
        (el) => !el.hasAttribute('disabled')
      );
      if (focusables.length === 0) {
        e.preventDefault();
        return;
      }

      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const active = document.activeElement;

      if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      }
    };

    document.addEventListener('keydown', handleKeydown);

    window.__searchCleanup = () => {
      focusObserver?.disconnect();
      focusObserver = null;
      trigger.removeEventListener('click', openSearch);
      backdrop.removeEventListener('click', closeSearch);
      document.removeEventListener('keydown', handleKeydown);
      document.body.style.overflow = '';
    };
  }

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: rgb(var(--color-accent) / 1);
    --pagefind-ui-text: rgb(var(--color-text-primary) / 1);
    --pagefind-ui-background: rgb(var(--color-surface) / 1);
    --pagefind-ui-border: rgb(var(--color-border) / 1);
    --pagefind-ui-tag: rgb(var(--color-surface-muted) / 1);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-font: inherit;
  }

  .pagefind-ui__form {
    position: relative;
  }

  .pagefind-ui__search-input {
    width: 100%;
    padding: 12px 16px;
    background: var(--pagefind-ui-background);
    border: none;
    border-bottom: 1px solid var(--pagefind-ui-border);
    color: var(--pagefind-ui-text);
    font-size: 16px;
    outline: none;
  }

  .pagefind-ui__search-input::placeholder {
    color: rgb(var(--color-text-secondary) / 1);
  }

  .pagefind-ui__search-clear {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgb(var(--color-text-secondary) / 1);
    cursor: pointer;
  }

  .pagefind-ui__results-area {
    max-height: 60vh;
    overflow-y: auto;
  }

  .pagefind-ui__results {
    padding: 8px;
  }

  .pagefind-ui__result {
    padding: 12px;
    border-radius: 4px;
  }

  .pagefind-ui__result:hover {
    background: rgb(var(--color-surface-muted) / 1);
  }

  .pagefind-ui__result-link {
    color: var(--pagefind-ui-text);
    text-decoration: none;
    font-weight: 500;
  }

  .pagefind-ui__result-link:hover {
    color: var(--pagefind-ui-primary);
  }

  .pagefind-ui__result-excerpt {
    color: rgb(var(--color-text-secondary) / 1);
    font-size: 14px;
    margin-top: 4px;
  }

  .pagefind-ui__message {
    padding: 16px;
    color: rgb(var(--color-text-secondary) / 1);
  }
</style>
