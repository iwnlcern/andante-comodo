---
interface Props {
  tag: string;
  href?: string;
  interactive?: boolean;
}

const { tag, href, interactive = false } = Astro.props;
const baseClass =
  'tag inline-block px-2 py-1 text-xs font-medium text-text-secondary bg-surface border border-border rounded transition-colors';
---

{interactive ? (
  <button
    type="button"
    data-tag={tag}
    class={`${baseClass} tag-filter hover:border-text-secondary hover:text-text-primary`}
    aria-pressed="false"
  >
    {tag}
  </button>
) : href ? (
  <a
    href={href}
    class={`${baseClass} hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/60 rounded-sm`}
  >
    {tag}
  </a>
) : (
  <span class={baseClass}>{tag}</span>
)}
