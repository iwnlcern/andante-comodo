---
import { THEME_STORAGE_KEY } from '#scripts/theme-key.mjs';
import { site } from '#config/site.mjs';

interface Props {
  title: string;
  description: string;
  image?: string;
  post?: boolean;
  datePublished?: Date;
  dateModified?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = site.meta.ogImage, post = false, datePublished, dateModified } = Astro.props;
const siteTitle = site.name;
const pageTitle = Astro.url.pathname === '/' ? siteTitle : `${title} — ${siteTitle}`;
const imageURL = new URL(image, Astro.site);
const faviconVersion = '2026-02-05';

// Serialize the BlogPosting JSON-LD, then HTML-escape for the raw-text <script>
// context before set:html: an author `title` containing `</script>` (or `<`, `>`,
// `&`, U+2028/U+2029) would otherwise break out of the element or inject markup.
const jsonLd = datePublished
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      datePublished: datePublished.toISOString(),
      ...(dateModified ? { dateModified: dateModified.toISOString() } : {}),
      author: { '@type': 'Person', name: site.name },
      url: canonicalURL.toString(),
      mainEntityOfPage: canonicalURL.toString(),
    })
      .replace(/</g, '\\u003c')
      .replace(/>/g, '\\u003e')
      .replace(/&/g, '\\u0026')
      .replace(/\u2028/g, '\\u2028')
      .replace(/\u2029/g, '\\u2029')
  : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="color-scheme" content="dark light" />

<!-- Preload the two faces every page needs (reading body + display headings) so the swap flash is minimal. -->
<link rel="preload" href="/fonts/EBGaramond-Variable.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/BodoniStd-Roman.woff2" as="font" type="font/woff2" crossorigin />

<script is:inline define:vars={{ storageKey: THEME_STORAGE_KEY }}>
  (() => {
    const root = document.documentElement;

    try {
      const storedTheme = localStorage.getItem(storageKey);
      const theme = storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : 'dark';
      root.dataset.theme = theme;
      root.style.colorScheme = theme;
    } catch {
      root.dataset.theme = root.dataset.theme || 'dark';
      root.style.colorScheme = root.dataset.theme;
    }
  })();
</script>
<link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${faviconVersion}`} sizes="any" />
<link rel="icon" type="image/png" href={`/favicon.png?v=${faviconVersion}`} sizes="32x32" />
<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={canonicalURL} />

<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />

<meta property="og:type" content={datePublished ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={pageTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

{
  datePublished && (
    <>
      <meta property="article:published_time" content={datePublished.toISOString()} />
      {dateModified && <meta property="article:modified_time" content={dateModified.toISOString()} />}
      <script type="application/ld+json" set:html={jsonLd} />
    </>
  )
}

<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title="RSS" href={site.social.rss} />
{
  post && (
    <script is:inline>
      (() => {
        try {
          var id = decodeURIComponent(location.hash.slice(1));
          if (id) {
            window.__arrivalHash = id;
            history.scrollRestoration = 'manual';
            history.replaceState(null, '', location.pathname + location.search);
            scrollTo(0, 0);
          }
        } catch (e) {}
      })();
    </script>
  )
}
