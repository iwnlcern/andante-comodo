---
import Search from '#components/search/Search.astro';
import { navCollections, standalonePages } from '#lib/content/collection-registry.mjs';
import { site } from '#config/site.mjs';

const currentPath = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '');
const navItems = [...navCollections(), ...standalonePages];

const isActive = (href) => currentPath === href || (href !== '/' && currentPath.startsWith(`${href}/`));

const desktopLinkClass = (href) =>
  [
    'inline-flex rounded px-3 py-1.5 text-sm font-medium transition-all duration-200',
    isActive(href)
      ? 'bg-surface-muted text-text-primary shadow-[0_6px_18px_rgba(15,23,42,0.12)]'
      : 'text-text-secondary hover:bg-surface-muted/70 hover:text-text-primary',
  ].join(' ');

const mobileLinkClass = (href) =>
  [
    'block rounded px-3 py-2 text-sm font-medium transition-colors',
    isActive(href)
      ? 'border border-border bg-surface-muted text-text-primary'
      : 'text-text-secondary hover:bg-surface hover:text-text-primary',
  ].join(' ');
---

<header class="w-full border-b border-border">
  <nav class="w-full px-6 py-4 grid grid-cols-[1fr_auto_1fr] items-center gap-4">
    <a
      href="/"
      class="min-w-0 text-lg font-semibold leading-tight text-text-primary hover:no-underline"
      style="margin-left: max(0px, (100vw - 64rem) / 2);"
    >{site.name}</a>
    <ul class="hidden lg:flex items-center gap-1 rounded border border-border bg-surface px-2 py-1 shadow-[0_12px_32px_rgba(15,23,42,0.08)]">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class={desktopLinkClass(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="flex items-center justify-end gap-3">
      <button
        type="button"
        data-theme-toggle
        class="inline-flex items-center gap-2 rounded border border-border px-3 py-1.5 text-sm text-text-secondary transition-colors hover:border-text-secondary hover:text-text-primary"
        aria-label="Switch to light mode"
        title="Switch to light mode"
      >
        <span aria-hidden="true" data-theme-toggle-icon>◐</span>
        <span class="hidden sm:inline" data-theme-toggle-label>Light</span>
      </button>
      <Search />
      <button
        id="mobile-nav-toggle"
        type="button"
        class="lg:hidden inline-flex items-center justify-center rounded border border-border px-3 py-1.5 text-sm text-text-secondary hover:border-text-secondary hover:text-text-primary transition-colors"
        aria-controls="mobile-nav-panel"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        Menu
      </button>
    </div>
  </nav>
  <div id="mobile-nav-panel" class="lg:hidden hidden border-t border-border bg-surface/80 backdrop-blur-sm">
    <ul class="px-6 py-3 grid gap-2">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class={mobileLinkClass(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  import { initMobileNav } from '#scripts/mobile-nav.ts';
  initMobileNav();
</script>
