<script>
  const initSortableTables = () => {
    window.__sortableTablesCleanup?.();
    const cleanups = [];

    const cellText = (row, i) => (row.children[i]?.textContent || '').trim();
    const isNumeric = (vals) =>
      vals.length > 0 && vals.every((v) => v !== '' && !Number.isNaN(Number(v.replace(/,/g, ''))));
    const compare = (type) => (a, b) => {
      if (type === 'num') return Number(a.replace(/,/g, '')) - Number(b.replace(/,/g, ''));
      if (type === 'date') return Date.parse(a) - Date.parse(b);
      return a.localeCompare(b);
    };

    document.querySelectorAll('.post-prose table.sortable').forEach((table) => {
      const tbody = table.querySelector('tbody');
      const headRow = table.querySelector('thead tr');
      if (!tbody || !headRow) return;
      const ths = [...headRow.querySelectorAll('th')];
      const original = [...tbody.querySelectorAll('tr')];
      const state = { col: -1, dir: 0 };

      const typeFor = (i) => {
        const declared = ths[i].dataset.sortType;
        if (declared && declared !== 'auto') return declared;
        return isNumeric(original.map((r) => cellText(r, i))) ? 'num' : 'text';
      };

      const sortBy = (i) => {
        if (state.col === i) state.dir = (state.dir + 1) % 3;
        else {
          state.col = i;
          state.dir = 1;
        }
        ths.forEach((th) => th.removeAttribute('aria-sort'));

        let rows;
        if (state.dir === 0) {
          rows = original;
          state.col = -1;
        } else {
          const cmp = compare(typeFor(i));
          const sign = state.dir === 2 ? -1 : 1;
          rows = [...original].sort((ra, rb) => sign * cmp(cellText(ra, i), cellText(rb, i)));
          ths[i].setAttribute('aria-sort', state.dir === 1 ? 'ascending' : 'descending');
        }
        rows.forEach((r) => tbody.appendChild(r));
      };

      ths.forEach((th, i) => {
        const handler = () => sortBy(i);
        th.addEventListener('click', handler);
        cleanups.push(() => th.removeEventListener('click', handler));
      });
    });

    window.__sortableTablesCleanup = () => {
      cleanups.forEach((fn) => fn());
      delete window.__sortableTablesCleanup;
    };
  };

  initSortableTables();
  if (!window.__sortableTablesBound) {
    window.__sortableTablesBound = true;
    document.addEventListener('astro:after-swap', initSortableTables);
  }
</script>
