{
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "compatibility_date": "2026-02-05",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "main": "@astrojs/cloudflare/entrypoints/server",
  "name": "andante-comodo",
  "observability": {
    "enabled": true
  }
}
